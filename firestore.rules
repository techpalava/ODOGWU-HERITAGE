rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return true; // Frontend uses mock auth, bypass for now
    }
    
    function isCustomer() {
      return true; // Frontend uses mock auth, bypass for now
    }

    match /fabrics/{fabricId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /styles/{styleId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /batches/{batchId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /showpieces/{showpieceId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /communityPhotos/{photoId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /customGroups/{groupId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /businessSettings/{document=**} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /settings/{document=**} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    match /media/{mediaId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Default deny for anything not explicitly matched above
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

